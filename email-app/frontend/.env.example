# Backend API Configuration
# Set the API base URL for your backend service
# This supports multiple frontend hosts pointing to the same backend

# Primary API URL - set this first
VITE_API_BASE_URL=http://localhost:8000/api

# Fallback API URL if primary fails
VITE_FALLBACK_API_URL=http://localhost:8000/api

# Example configurations for different environments:

# Development (localhost)
# VITE_API_BASE_URL=http://localhost:8000/api

# Replit Pike Environment
# VITE_API_BASE_URL=https://5474f674-6074-4eb8-8818-15946bef35a1-00-1y8lhfj74gqcq.pike.replit.dev:8000/api

# Replit Picard Environment
# VITE_API_BASE_URL=https://1e3e51b5-d74b-43fc-9d8d-5d25ea6cb6c7-00-3fzv7fuo5ld08.picard.replit.dev/api

# Production
# VITE_API_BASE_URL=https://your-production-domain.com/api
